<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- App Theme — Edge-to-Edge:
         windowFullscreen=false + keine StatusBar-Farbe → App zeichnet
         hinter StatusBar + NavBar. Die korrekten Safe-Area-Insets werden
         via WindowInsetsCompat an CSS env(safe-area-inset-*) weitergeleitet.
         ⚠️  windowFullscreen=true würde env(safe-area-inset-bottom)=0 zwingen! -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/splash_background</item>
        <item name="android:windowNoTitle">true</item>
        <!-- WICHTIG: NICHT windowFullscreen=true — bricht Safe-Area-Insets -->
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>

        <!-- Edge-to-Edge: App zeichnet hinter System-Bars -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Android 10+ (API 29): Gesturenavigation nahtlos -->
        <item name="android:enforceStatusBarContrast" tools:targetApi="q">false</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="q">false</item>

        <!-- WebView Performance -->
        <item name="android:hardwareAccelerated">true</item>
    </style>

    <!-- Launch Theme (SplashScreen) -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/splash</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

</resources>
