{
  "outputDirectory": "www",
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/beitrag/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|twitterbot|slackbot|telegrambot|discordbot|linkedinbot|whatsapp|applebot|googlebot|bingbot|pinterest|vkshare|ia_archiver).*"
        }
      ],
      "destination": "/api/og?path=/beitrag/:id"
    },
    {
      "source": "/projekt/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|twitterbot|slackbot|telegrambot|discordbot|linkedinbot|whatsapp|applebot|googlebot|bingbot|pinterest|vkshare|ia_archiver).*"
        }
      ],
      "destination": "/api/og?path=/projekt/:id"
    },
    {
      "source": "/erlebnis/:id",
      "has": [
        {
          "type": "header",
