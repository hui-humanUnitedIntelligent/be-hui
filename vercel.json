{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/assets/$1" },

    { "source": "/beitrag/:id",       "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(facebookexternalhit|twitterbot|slackbot|telegrambot|discordbot|linkedinbot|whatsapp|signal|imessage|applebot|googlebot|bingbot|ia_archiver|pinterest|vkshare|xing-contenttabreceiver|curl|python-requests|wget).*" }], "destination": "/api/og.cjs?path=/beitrag/:id" },
    { "source": "/projekt/:id",       "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(facebookexternalhit|twitterbot|slackbot|telegrambot|discordbot|linkedinbot|whatsapp|signal|imessage|applebot|googlebot|bingbot|ia_archiver|pinterest|vkshare|xing-contenttabreceiver|curl|python-requests|wget).*" }], "destination": "/api/og.cjs?path=/projekt/:id" },
    { "source": "/erlebnis/:id",      "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(facebookexternalhit|twitterbot|slackbot|telegrambot|discordbot|linkedinbot|whatsapp|signal|imessage|applebot|googlebot|bingbot|ia_archiver|pinterest|vkshare|xing-contenttabreceiver|curl|python-requests|wget).*" }], "destination": "/api/og.cjs?path=/erlebnis/:id" },
    { "source": "/veranstaltung/:id", "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(facebookexternalhit|twitterbot|slackbot|telegrambot|discordbot|linkedinbot|whatsapp|signal|imessage|applebot|googlebot|bingbot|ia_archiver|pinterest|vkshare|xing-contenttabreceiver|curl|python-requests|wget).*" }], "destination": "/api/og.cjs?path=/veranstaltung/:id" },
    { "source": "/werke/:slug",       "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(facebookexternalhit|twitterbot|slackbot|telegrambot|discordbot|linkedinbot|whatsapp|signal|imessage|applebot|googlebot|bingbot|ia_archiver|pinterest|vkshare|xing-contenttabreceiver|curl|python-requests|wget).*" }], "destination": "/api/og.cjs?path=/werke/:slug" },
    { "source": "/wirker/:username",  "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(facebookexternalhit|twitterbot|slackbot|telegrambot|discordbot|linkedinbot|whatsapp|signal|imessage|applebot|googlebot|bingbot|ia_archiver|pinterest|vkshare|xing-contenttabreceiver|curl|python-requests|wget).*" }], "destination": "/api/og.cjs?path=/wirker/:username" },
    { "source": "/profile/:username", "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(facebookexternalhit|twitterbot|slackbot|telegrambot|discordbot|linkedinbot|whatsapp|signal|imessage|applebot|googlebot|bingbot|ia_archiver|pinterest|vkshare|xing-contenttabreceiver|curl|python-requests|wget).*" }], "destination": "/api/og.cjs?path=/wirker/:username" },
    { "source": "/work/:id",          "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(facebookexternalhit|twitterbot|slackbot|telegrambot|discordbot|linkedinbot|whatsapp|signal|imessage|applebot|googlebot|bingbot|ia_archiver|pinterest|vkshare|xing-contenttabreceiver|curl|python-requests|wget).*" }], "destination": "/api/og.cjs?path=/work/:id" },

    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/(.*)",        "destination": "/index.html" }
  ],
  "functions": {
    "api/og.cjs": {
      "maxDuration": 10
    },
    "api/og-image.cjs": {
      "maxDuration": 10,
      "memory": 1024
    }
  }
